{
  "compilerOptions": {
    "baseUrl": ".",
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false,
    "exactOptionalPropertyTypes": false,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "paths": {
      "@argent/core": ["./packages/core/src/index.ts"],
      "@argent/core/*": ["./packages/core/src/*"],
      "@argent/llm": ["./packages/llm/src/index.ts"],
      "@argent/llm/*": ["./packages/llm/src/*"],
      "@argent/integrations": ["./packages/integrations/src/index.ts"],
      "@argent/integrations/*": ["./packages/integrations/src/*"]
    }
  },
  "include": ["packages/*/src/**/*.ts", "packages/*/src/**/*.tsx", "packages/*/test/**/*.ts"],
  "exclude": ["node_modules", "packages/*/dist"]
}
