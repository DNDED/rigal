    "build:binary": "bun run script/build.ts --compile",
    "start": "bun dist/main.js"
  },
  "keywords": [
    "ai",
    "coding",
    "agent",
    "cli",
    "llm",
    "openai",
    "anthropic",
    "claude",
    "gpt",
    "codex",
    "gemini",
    "deepseek",
    "ollama"
  ],
  "author": "ARGENT Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/DNDED/argent"
  },
  "homepage": "https://argent.dev",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "effect": "^3.14.0",
    "ink": "^5.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.0",
    "react-devtools-core": "^7.0.1",
    "react-reconciler": "^0.29.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0"
  }
