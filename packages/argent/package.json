{
  "name": "argent",
  "version": "0.4.0",
  "description": "ARGENT — The universal AI coding harness. Any model, any provider, any platform.",
  "type": "module",
  "main": "dist/main.js",
  "bin": {
    "argent": "./bin/argent"
  },
  "files": [
    "bin/",
    "dist/main.js",
    "README.md"
  ],
  "scripts": {
    "dev": "bun run --watch src/cli/main.tsx",
