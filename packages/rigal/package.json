{
  "name": "rigal",
  "version": "0.2.0",
  "description": "RIGAL — The universal AI coding harness. Any model, any provider, any platform.",
  "type": "module",
  "main": "dist/main.js",
  "bin": {
    "rigal": "./bin/rigal"
  },
  "files": [
    "bin/",
    "dist/",
    "README.md"
  ],
  "scripts": {
    "dev": "bun run --watch src/cli/main.tsx",
    "build": "bun run script/build.ts",
    "build:binary": "bun run script/build.ts --compile",
    "start": "bun dist/main.js",
    "prepack": "bun run build"
  },
  "keywords": [
    "ai",
    "coding",
    "agent",
    "cli",
    "llm",
    "openai",
    "anthropic",
    "claude",
    "gpt",
    "codex",
    "gemini",
    "deepseek",
    "ollama"
  ],
  "author": "RIGAL Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rigal-ai/rigal"
  },
  "homepage": "https://rigal.dev",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@rigal/core": "workspace:*",
    "@rigal/llm": "workspace:*",
    "@rigal/integrations": "workspace:*",
    "ink": "^5.2.0",
    "ink-text-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "react": "^18.3.0",
    "react-reconciler": "^0.29.0",
    "effect": "^3.14.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0"
  }
}
