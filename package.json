{
  "name": "argent",
  "version": "0.4.0",
  "private": true,
  "description": "ARGENT — The universal AI coding harness. Any model, any provider, any platform.",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --cwd packages/argent dev",
    "build": "bun run --cwd packages/argent build",
    "build:binary": "bun run --cwd packages/argent build:binary",
    "typecheck": "bun x tsc --noEmit -p tsconfig.json",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "lint": "bun x oxlint",
    "format": "bun x prettier --write .",

    "clean": "rm -rf packages/*/dist"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "oxlint": "^0.18.0",
    "prettier": "^3.6.0",
    "typescript": "^5.9.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
